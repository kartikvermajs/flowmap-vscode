{
  "name": "flowmap",
  "displayName": "FlowMap",
  "publisher": "flowmap-dev",
  "description": "Visualizes frontend \u2192 backend API connections locally",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./dist/index.js",
  "contributes": {
    "commands": [
      {
        "command": "flowmap.scanProject",
        "title": "FlowMap: Scan Project"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "clean": "node -e \"const fs=require('fs'); ['dist', 'ui/dist'].forEach(d => fs.rmSync(d, {recursive:true, force:true}))\"",
    "build": "npm run clean && npm run compile && npm run build:ui",
    "compile": "tsup",
    "watch": "tsup --watch",
    "package": "tsup --minify",
    "build:ui": "cd ui && npm install && npm run build"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.0.0",
    "tsup": "^8.0.0"
  }
}